# Variables de entorno del backend — NN Auth System
# ¿Para qué? Separar configuración sensible del código fuente.
#             Este archivo NO debe versionarse en git (.gitignore lo excluye).
# ¿Impacto? Si se versiona con credenciales reales, compromete la seguridad del sistema.
# Instrucción: copiar este archivo como .env y completar con valores reales.

# JDK — ruta al JDK completo (con javac) requerido por Maven
# Verificar con: find /usr/lib/jvm -name "javac"
JAVA_HOME=/usr/lib/jvm/java-21-openjdk

# Base de datos PostgreSQL 17
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nn_auth_db
DB_USERNAME=nn_user
DB_PASSWORD=nn_password

# JWT — seguridad de tokens
# IMPORTANTE: cambiar por una clave aleatoria de al menos 32 caracteres en producción
# Generar con: openssl rand -hex 64
JWT_SECRET=dev-secret-key-min-32-chars-change-in-production-do-not-use
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# Servidor de email (Mailpit en desarrollo)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# URLs y entorno
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Swagger UI — true en desarrollo, false en producción
SWAGGER_UI_ENABLED=true
